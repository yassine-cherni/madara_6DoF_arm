<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="madara">

  <!-- Real hardware: UART bridge to Arduino Uno
       Plugin: madara_hardware_interface/MadaraUARTSystem

       FIX: serial_port is now declared here as a top-level xacro arg.
            This is the entry point when bringup_launch.py runs:
              xacro real_madara.urdf.xacro serial_port:=/dev/ttyACM0
            Without this declaration xacro rejects the command-line arg.
            The default matches the arg default in madara.ros2_control.xacro
            so both files agree when no override is given.                 -->
  <xacro:arg name="serial_port" default="/dev/ttyACM0"/>

  <xacro:include filename="$(find madara_description)/urdf/madara.urdf.xacro"/>
  <xacro:include filename="$(find madara_description)/urdf/madara.ros2_control.xacro"/>

  <xacro:madara_ros2_control
    name="MadaraRealSystem"
    plugin_name="madara_hardware_interface/MadaraUARTSystem"/>

</robot>
